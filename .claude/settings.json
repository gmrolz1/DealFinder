{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "_comment": "Project-level Claude Code settings for DealFinder. Loaded automatically by every teammate's Claude Code. Edit with care — changes affect the whole team.",
  "permissions": {
    "allow": [
      "Bash(npm run dev)",
      "Bash(npm run build)",
      "Bash(npm run lint)",
      "Bash(npm run start)",
      "Bash(npm install)",
      "Bash(npm ci)",
      "Bash(npx tsc --noEmit)",
      "Bash(node scraper/scrape.mjs:*)",
      "Bash(node scripts/process-logo.mjs)",
      "Bash(git status)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git branch:*)",
      "Bash(git remote -v)",
      "Bash(git show:*)",
      "Bash(git fetch:*)",
      "Bash(git pull --ff-only)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git checkout -b *)",
      "Bash(git stash:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(echo:*)",
      "Bash(curl -I:*)",
      "Bash(curl -s:*)",
      "Bash(node --version)",
      "Bash(npm --version)"
    ],
    "ask": [
      "Bash(git push:*)",
      "Bash(git merge:*)",
      "Bash(git rebase:*)",
      "Bash(git tag:*)",
      "Bash(npm install *)",
      "Bash(npm uninstall *)",
      "Bash(node scraper/load-supabase.mjs)",
      "Bash(rm:*)",
      "Bash(mv:*)",
      "Bash(cp:*)",
      "Bash(gh pr create:*)",
      "Bash(gh pr merge:*)",
      "Bash(vercel:*)"
    ],
    "deny": [
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(git reset --hard*)",
      "Bash(git clean -fd*)",
      "Bash(git clean -fdx*)",
      "Bash(git checkout -- *)",
      "Bash(git commit --no-verify*)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~*)",
      "Bash(rm -rf .git*)",
      "Bash(rm -rf node_modules)",
      "Bash(npm install -g *)",
      "Bash(sudo *)",
      "Bash(curl * | bash)",
      "Bash(curl * | sh)",
      "Read(./.env.local)",
      "Read(./.env)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/block-secrets.sh"
          }
        ]
      }
    ]
  }
}
