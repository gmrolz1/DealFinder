# Copy this file to .env.local and fill in real values.
# .env.local is git-ignored — never commit it.
#
# The publishable (anon) key is safe to expose: it ships in the browser
# bundle and is gated by Row Level Security.

NEXT_PUBLIC_SUPABASE_URL=https://nmrzefvdixmxmhmxojlv.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_HEcmkn2POVZDKLlFt2IlQA_6SP_lsK2

# Optional — only needed to run the data loader (scraper/load-supabase.mjs).
# Get this from Supabase → Project Settings → API Keys → Secret keys → reveal.
# NEVER commit the secret key.
# SUPABASE_SERVICE_ROLE_KEY=

# Optional — only needed if you set up a custom domain.
# NEXT_PUBLIC_SITE_URL=https://deal-finder-nu.vercel.app

# Required for the AI chat agent (used by /api/chat).
# Get from https://aistudio.google.com/apikey — keep server-only, never commit.
# GEMINI_API_KEY=
